# Copy this file to .env.local and fill in real values there.
# .env.local is gitignored; this file (.env.example) is committed, so never put
# real secrets in it.

# Stripe (https://dashboard.stripe.com/apikeys)
# Use your test keys (sk_test_...) while developing, live keys (sk_live_...) in production.
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret for /api/webhooks/stripe
# Dev: `stripe listen --forward-to localhost:3000/api/webhooks/stripe` prints this.
# Prod: create an endpoint in the Stripe Dashboard -> Developers -> Webhooks, subscribe to
# "checkout.session.completed", and copy its signing secret here.
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_...

# Verified sender address. Until a domain is verified in Resend, leave this unset to use
# Resend's shared sandbox sender ("onboarding@resend.dev"), which only delivers to your own
# Resend account email. Once you verify sanatansamajaus.com.au (or another domain) in Resend,
# set this to e.g. "Sanatan Samaj Australia <membership@sanatansamajaus.com.au>".
RESEND_FROM_EMAIL=

# MongoDB connection string (e.g. from MongoDB Atlas: Database -> Connect -> Drivers).
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=sanatansamaj
